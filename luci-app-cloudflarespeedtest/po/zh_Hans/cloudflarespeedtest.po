msgid "<a href=\"https://github.com/stevenjoezhang/luci-app-cloudflarespeedtest\" target=\"_blank\">⭐ Star on GitHub</a>"
msgstr "<a href=\"https://github.com/stevenjoezhang/luci-app-cloudflarespeedtest\" target=\"_blank\">⭐ 在 GitHub 上关注</a>"

msgid "Cloudflare Speed Test"
msgstr "Cloudflare 速度测试"

msgid "Schedules and runs CloudflareSpeedTest with the selected IP list, automatically applying the fastest IPs to supported integrations"
msgstr "使用所选 IP 列表定时运行 CloudflareSpeedTest，并自动将最快 IP 应用到支持的集成"

msgid "Plugin Settings"
msgstr "插件设置"

msgid "Third Party Settings"
msgstr "第三方设置"

msgid "Basic Settings"
msgstr "基础设置"

msgid "Crontab Settings"
msgstr "计划任务设置"

msgid "Logs"
msgstr "日志"

msgid "Test latency and speed for all IPs in the selected CDN or website list, then apply the fastest IP (IPv4 + IPv6 supported)"
msgstr "测试所选 CDN 或网站列表中所有 IP 的延迟和速度，并应用最快 IP（支持 IPv4 + IPv6）"

msgid "Enabled"
msgstr "启用"

msgid "Enable scheduled task to test the selected IP list"
msgstr "启用计划任务测试所选 IP 列表"

msgid "Speed threshold (MB/s)"
msgstr "速度阈值（MB/s）"

msgid "Custom URL"
msgstr "自定义地址"

msgid "Enable custom cron"
msgstr "启用自定义 Cron"

msgid "Custom Cron"
msgstr "自定义 Cron"

msgid "Example: 0 */3 * * *"
msgstr "例如: 0 */3 * * *"

msgid "Interval"
msgstr "间隔"

msgid "Every %d hour(s)"
msgstr "每 %d 小时"

msgid "Only IPs with a download speed greater than this threshold will be retained. Please note, do not set this value too high — if no IP meets the requirement, CloudflareSpeedTest may waste excessive time and resources"
msgstr "只有下载速度大于这个阈值的 IP 会被保留。请注意，不要将其设置为过于大的值，如果无法找到满足要求的 IP，CloudflareSpeedTest 可能会浪费过多的时间和资源"

msgid "ShadowSocksR Plus+ Enabled"
msgstr "启用 ShadowSocksR Plus+"

msgid "Passwall Enabled"
msgstr "启用 Passwall"

msgid "PassWall2 Enabled"
msgstr "启用 PassWall2"

msgid "Bypass Enabled"
msgstr "启用 Bypass"

msgid "Vssr Enabled"
msgstr "启用 Vssr"
