#: applications/luci-app-aurora-config/htdocs/luci-static/resources/view/aurora/theme.js:1007
msgid ""
"Sans-serif sets the global UI typeface for all text and headings. Monospace "
"is used for code blocks, inline code, and variable references."
msgstr "Sans-serif define la tipografía global de la interfaz para todos los textos y títulos. Monospace (monoespaciada) se utiliza en bloques de código, código incrustado y referencias a variables."

